# API keys
OPENAI_API_KEY=sk-your-key-here
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Training — base model for LoRA fine-tuning
# Selected by setup.sh. Choose from:
#   unsloth/Llama-3.2-3B-Instruct     (3B, fast)
#   unsloth/Qwen2.5-3B-Instruct       (3B, fast)
#   unsloth/Mistral-7B-Instruct-v0.3  (7B, balanced)
#   unsloth/Llama-3.1-8B-Instruct     (8B, balanced)
#   unsloth/Llama-3.3-70B-Instruct    (70B, cloud only)
LOCALDISTILL_MODEL=unsloth/Llama-3.2-3B-Instruct